#!/bin/bash
PID_FILE="/tmp/study_alarm.pid"
LOG_FILE="/tmp/study_alarm.log"
LOCK_DIR="/tmp/study_alarm.lock"
SCRIPT="$(dirname "$(python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "${BASH_SOURCE[0]:-$0}")")/alarm.py"

is_running() {
    [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

print_help() {
    cat <<'EOF'
study_alarm — Sessiz görsel alarm (kütüphane / ofis için)

KULLANIM:
  study_alarm HH:MM            Belirtilen saatte alarm kur
  study_alarm --in N           N dakika sonrasına alarm kur
  study_alarm --message "..."  Özel mesajlı alarm kur
  study_alarm --test           5 saniye sonra test alarmı
  study_alarm --stop            Çalışan alarmı durdur
  study_alarm --status         Alarm durumunu göster
  study_alarm --uninstall      Programı tamamen kaldır
  study_alarm --help           Bu yardımı göster

SEÇENEKLER:
  --force                      Başka alarm çalışıyorsa üstüne yaz
  --in N                       N dakika sonrasına alarm kur (örn: --in 15)
  --message "..."               Alarm ekranında gösterilecek özel mesaj
  --test                       5 saniyelik test alarmı

ÖRNEKLER:
  study_alarm 16:25            Saat 16:25'te çal
  study_alarm --in 15          15 dakika sonra çal
  study_alarm --in 70          1 saat 10 dakika sonra çal
  study_alarm 16:25 --message "Toplantı!"   Özel mesajlı alarm
  study_alarm 16.25 --force    Çalışan alarm varsa üstüne yaz
  study_alarm --test           Hemen test et (5 saniye)
  study_alarm --stop           Durdur
  study_alarm --status         Duruma bak
  study_alarm --uninstall      Programı sil

NOT:
  - Terminali kapatabilirsin, alarm arka planda çalışır
  - caffeinate otomatik uygulanır, Mac uykuya geçmez
  - Alarm ateşlenince ESC ile kapat
EOF
}

validate_time() {
    local t="$1"
    if [[ ! "$t" =~ ^[0-9]{1,2}[.:][0-9]{2}$ ]]; then
        echo "HATA: Gecersiz saat formati: '$t'"
        echo "Dogru kullanim: 16:25  veya  9:05  veya  16.25"
        return 1
    fi
    local h="${t%[.:]*}"
    local m="${t##*[.:]}"
    h=$((10#$h))
    m=$((10#$m))
    if [ "$h" -lt 0 ] || [ "$h" -gt 23 ]; then
        echo "HATA: Saat 0-23 arasinda olmali, girilen: $h"
        return 1
    fi
    if [ "$m" -lt 0 ] || [ "$m" -gt 59 ]; then
        echo "HATA: Dakika 0-59 arasinda olmali, girilen: $m"
        return 1
    fi
    local now_minutes=$(( $(date +%H) * 60 + $(date +%M) ))
    local target_minutes=$(( h * 60 + m ))
    if [ "$target_minutes" -le "$now_minutes" ]; then
        echo "HATA: $t gecmiste kaldi. Ileri bir saat girin."
        return 1
    fi
    return 0
}

# --- Parse arguments ---
FORCE=false
TEST_MODE=false
IN_MODE=false
IN_MINUTES=""
TEST_FLAG=""
IN_FLAG=""
TIME_ARG=""
ALARM_MESSAGE=""
UNKNOWN=""

while [ $# -gt 0 ]; do
    case $1 in
        --help|-h)
            print_help
            exit 0
            ;;
        --stop)
            if is_running; then
                PID=$(cat "$PID_FILE")
                kill "$PID" 2>/dev/null
                rm -f "$PID_FILE" "$LOG_FILE"
                echo "Alarm durduruldu (PID: $PID)."
            else
                echo "Calisan alarm yok."
            fi
            exit 0
            ;;
        --uninstall)
            INSTALL_DIR="$(dirname "$(python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "${BASH_SOURCE[0]:-$0}")")"
            LINK="$HOME/bin/study_alarm"
            echo "study_alarm kaldırılıyor..."
            if is_running; then
                PID="$(cat "$PID_FILE")"
                kill "$PID" 2>/dev/null
                rm -f "$PID_FILE" "$LOG_FILE"
                echo "Calisan alarm durduruldu (PID: $PID)."
            fi
            [ -L "$LINK" ] && rm -f "$LINK" && echo "Symlink silindi: $LINK"
            [ -d "$INSTALL_DIR" ] && rm -rf "$INSTALL_DIR" && echo "Dosyalar silindi: $INSTALL_DIR"
            for rc in "$HOME/.zshrc" "$HOME/.bash_profile" "$HOME/.profile"; do
                if [ -f "$rc" ] && grep -q 'export PATH="$HOME/bin:$PATH"' "$rc" 2>/dev/null; then
                    sed -i '' '\|export PATH="\$HOME/bin:\$PATH"|d' "$rc"
                    echo "PATH satırı temizlendi: $rc"
                fi
            done
            echo "Kaldırma tamam. Güle güle!"
            exit 0
            ;;
        --status)
            if is_running; then
                PID=$(cat "$PID_FILE")
                echo "Alarm calisiyor (PID: $PID)"
                echo "---"
                grep "^Alarm kuruldu" "$LOG_FILE" 2>/dev/null | tail -1
                grep "^Kalan: " "$LOG_FILE" 2>/dev/null | tail -1
            else
                echo "Calisan alarm yok."
            fi
            exit 0
            ;;
        --force)
            FORCE=true
            shift
            ;;
        --test)
            TEST_MODE=true
            shift
            ;;
        --in)
            shift
            if [ $# -eq 0 ]; then
                echo "HATA: --in icin dakika degeri gerekli."
                echo "Ornek: study_alarm --in 15"
                exit 1
            fi
            IN_MINUTES="$1"
            shift
            ;;
        --message)
            shift
            if [ $# -eq 0 ]; then
                echo "HATA: --message icin bir mesaj gerekli."
                echo "Ornek: study_alarm 16:25 --message \"Toplanti!\""
                exit 1
            fi
            ALARM_MESSAGE="$1"
            shift
            ;;
        --*)
            UNKNOWN="$1"
            shift
            ;;
        *)
            if [ -z "$TIME_ARG" ]; then
                TIME_ARG="$1"
            else
                echo "HATA: Birden fazla saat girildi: '$TIME_ARG' ve '$1'"
                echo "Kullanim: study_alarm HH:MM"
                exit 1
            fi
            shift
            ;;
    esac
done

# --- Unknown flag ---
if [ -n "$UNKNOWN" ]; then
    echo "HATA: Bilinmeyen secenek: $UNKNOWN"
    echo "Kullanilabilir secenekler: --help, --stop, --status, --uninstall, --test, --force, --in, --message"
    exit 1
fi

# --- --force without time ---
if $FORCE && [ -z "$TIME_ARG" ] && ! $TEST_MODE && [ -z "$IN_MINUTES" ]; then
    echo "HATA: --force tek basina kullanilamaz. Bir saat belirtin."
    echo "Ornek: study_alarm 16:25 --force"
    exit 1
fi

# --- --in validation ---
if [ -n "$IN_MINUTES" ]; then
    if [ -n "$TIME_ARG" ]; then
        echo "HATA: --in ile saat birlikte kullanilamaz."
        echo "Kullanim: study_alarm --in 15  VEYA  study_alarm 16:25"
        exit 1
    fi
    if $TEST_MODE; then
        echo "HATA: --in ile --test birlikte kullanilamaz."
        exit 1
    fi
    if ! [[ "$IN_MINUTES" =~ ^[0-9]+$ ]]; then
        echo "HATA: --in icin gecerli bir sayi girin. Harf veya ozel karakter girilemez."
        echo "Ornek: study_alarm --in 15"
        exit 1
    fi
    if [ "$IN_MINUTES" -le 0 ]; then
        echo "HATA: --in icin pozitif bir sayi girin (en az 1 dakika)."
        exit 1
    fi
    if [ "$IN_MINUTES" -gt 1440 ]; then
        echo "HATA: --in en fazla 1440 dakika (24 saat) olabilir."
        echo "Daha ileri tarih icin: study_alarm HH:MM"
        exit 1
    fi
    IN_MODE=true
    TIME_ARG=$(date -v+"${IN_MINUTES}"M "+%H:%M")
    IN_FLAG="--in"
fi

# --- Test mode ---
if $TEST_MODE; then
    if [ -n "$TIME_ARG" ]; then
        echo "HATA: --test ile saat birlikte kullanilamaz."
        echo "Test: study_alarm --test"
        echo "Normal: study_alarm 16:25"
        exit 1
    fi
    FORCE=true
    TIME_ARG=$(date -v+5S "+%H:%M")
    TEST_FLAG="--test"
    echo "Test modu: 5 saniye sonra ($TIME_ARG) ekran kirmizi olacak..."
fi

# --- No time ---
if [ -z "$TIME_ARG" ]; then
    echo "HATA: Saat belirtilmedi."
    echo "Kullanim: study_alarm HH:MM  |  study_alarm --in N  |  study_alarm --test  |  study_alarm --help"
    exit 1
fi

# --- Validate time format (skip for --test and --in, time is auto-generated) ---
if ! $TEST_MODE && ! $IN_MODE; then
    validate_time "$TIME_ARG" || exit 1
fi

# --- Acquire lock (prevents race condition on concurrent launches) ---
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    echo "HATA: Baska bir study_alarm islemi devam ediyor. Lutfen bekleyin."
    exit 1
fi
cleanup_lock() { rmdir "$LOCK_DIR" 2>/dev/null; }
trap cleanup_lock EXIT

# --- Already running check ---
if is_running && ! $FORCE; then
    echo "Zaten bir alarm calisiyor! (PID: $(cat "$PID_FILE"))"
    echo "Durdurmak -> study_alarm --stop"
    echo "Ustune yaz -> study_alarm $TIME_ARG --force"
    exit 1
fi

if is_running && $FORCE; then
    kill "$(cat "$PID_FILE")" 2>/dev/null
    rm -f "$PID_FILE" "$LOG_FILE"
    echo "Onceki alarm iptal edildi, yenisi kuruluyor..."
fi

# --- Launch ---
CMD_ARGS=("$SCRIPT" "$TIME_ARG" "--pid-file" "$PID_FILE")
[ -n "$TEST_FLAG" ] && CMD_ARGS+=("$TEST_FLAG")
[ -n "$IN_FLAG" ] && CMD_ARGS+=("$IN_FLAG")
[ -n "$ALARM_MESSAGE" ] && CMD_ARGS+=(--message "$ALARM_MESSAGE")

nohup caffeinate python3 "${CMD_ARGS[@]}" > "$LOG_FILE" 2>&1 &
PID=$!
echo "$PID" > "$PID_FILE"

if $IN_MODE; then
    echo "Alarm kuruldu: $TIME_ARG  (${IN_MINUTES} dakika sonra)"
else
    echo "Alarm kuruldu: $TIME_ARG"
fi
echo "PID: $PID  |  Terminali kapatabilirsin"
echo "Durum: study_alarm --status  |  Durdur: study_alarm --stop"
